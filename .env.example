# GrabOn Underwriting Agent — Environment Variables
# Copy this to .env and fill in your values

# Claude API (optional — falls back to deterministic rationale if not set)
ANTHROPIC_API_KEY=

# Twilio WhatsApp Sandbox (optional — falls back to mock delivery if not set)
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# IMPORTANT: To use Twilio WhatsApp Sandbox:
# 1. Go to https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
# 2. Send "join <sandbox-keyword>" from your WhatsApp to +14155238886
# 3. Update the merchant whatsapp_numbers in merchant_profiles.py to YOUR number
#    (the sandbox can only send to numbers that have joined)
